// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  // previewFeatures = ["metrics"]
  previewFeatures = ["relationJoins"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  // NOTE: デプロイ時はコメント解除が必要
  // DEPLOY: binaryTargets   = ["native", "rhel-openssl-1.0.x"]
  // DEPLOY: output          = "../node_modules/.prisma/client"
}

generator fabbrica {
  provider = "prisma-fabbrica"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @db.Uuid
  displayName   String         @map("display_name") @db.VarChar(50)
  accountName   String         @unique @map("account_name") @db.VarChar(50)
  email         String         @unique @db.VarChar(255)
  emailVerified Boolean        @default(false) @map("email_verified")
  providerId    String         @default("") @map("provider_id") @db.VarChar(50)
  notifications Notification[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  Feed          Feed[]

  @@index([displayName])
  @@index([providerId])
  @@map("users")
}

model Notification {
  id        String   @id @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(255)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("notifications")
}

model Feed {
  id           String     @id @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  user         User       @relation(fields: [userId], references: [id])
  name         String     @db.VarChar(100)
  url          String     @default("") @db.Text
  cycle        Int        @default(0)
  dataSourceId String     @map("data_source_id") @db.Uuid
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id])
  feedLogs     FeedLog[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("feeds")
}

model DataSource {
  id        String   @id @db.Uuid
  name      String   @db.VarChar(100)
  url       String   @db.Text
  // type: 将来的に追加する
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  Feed      Feed[]

  @@map("data_sources")
}

model FeedLog {
  id        String   @id @db.Uuid
  feedId    String   @map("feed_id") @db.Uuid
  feed      Feed     @relation(fields: [feedId], references: [id])
  date      DateTime @map("date") @db.Timestamptz
  title     String   @db.VarChar(255)
  summary   String   @db.Text
  body      String?  @db.Text
  url       String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([feedId])
  @@index([date])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("feed_logs")
}
