{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "build-api-client": "openapi-zod-client http://localhost:3001/local/openapi.json -o ./src/lib/api/client.generated.ts --all-readonly --strict-objects",
    "postinstall": "nuxt prepare",
    "lint:eslint": "eslint .",
    "lint:tsc": "vue-tsc --noEmit",
    "lint:prettier": "prettier --check '**/*.vue'",
    "lint:biome": "biome check --config-path=../../biome.json .",
    "lint": "npm-run-all2 lint:eslint lint:tsc lint:biome",
    "format:biome": "biome format --write src .storybook eslint.config.mjs nuxt.config.ts tailwind.config.ts vitest.config.ts",
    "format:prettier": "prettier --write '**/*.vue'",
    "format": "npm-run-all2 format:biome format:prettier",
    "test": "vitest"
  },
  "dependencies": {
    "@nuxt/eslint": "^0.6.2",
    "@nuxt/icon": "^1.7.2",
    "@nuxtjs/storybook": "^8.3.3",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@pinia/nuxt": "^0.5.5",
    "@storybook/addon-essentials": "^8.5.6",
    "@storybook/addon-interactions": "^8.5.6",
    "@storybook/addon-links": "^8.5.6",
    "@storybook/vue3": "^8.5.6",
    "@tanstack/vue-form": "^0.36.2",
    "@tanstack/zod-form-adapter": "^0.36.2",
    "@zodios/core": "^10.9.6",
    "axios": "^1.7.9",
    "core": "workspace:*",
    "dayjs": "^1.11.13",
    "nuxt": "^3.15.4",
    "nuxt-auth-utils": "^0.5.15",
    "ofetch": "^1.4.1",
    "pinia": "^2.2.4",
    "serverless-s3-sync": "^3.4.0",
    "tailwind-merge": "^2.5.4",
    "tailwind-variants": "^0.3.1",
    "tailwindcss": "^3.4.14",
    "vue": "latest",
    "vue-router": "latest",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@nuxt/test-utils": "^3.15.1",
    "@types/auth0-js": "^9.21.6",
    "@types/eslint__eslintrc": "^2.1.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "config": "link:@nuxt/test-utils/config",
    "eslint": "^9.12.0",
    "h3": "^1.13.0",
    "happy-dom": "^15.11.7",
    "npm-run-all2": "^6.2.3",
    "openapi-zod-client": "^1.18.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "rollup": "^4.24.0",
    "serverless": "^4.4.6",
    "serverless-domain-manager": "^8.0.0",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.2.2"
  },
  "overrides": {
    "vue": "latest"
  }
}
